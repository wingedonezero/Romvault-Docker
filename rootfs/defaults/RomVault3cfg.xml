  <FilesOnly>false</FilesOnly>
  <DatRoot>DatRoot</DatRoot>
  <CacheFile>RomVault3_3.Cache</CacheFile>
  <FixLevel>Level2</FixLevel>
  <DatRules>
    <DatRule>
      <DirKey>RomVault</DirKey>
      <Compression>Zip</Compression>
      <CompressionOverrideDAT>false</CompressionOverrideDAT>
      <Merge>None</Merge>
      <HeaderType>Optional</HeaderType>
      <MergeOverrideDAT>false</MergeOverrideDAT>
      <SingleArchive>false</SingleArchive>
      <MultiDATDirOverride>false</MultiDATDirOverride>
      <IgnoreFiles />
