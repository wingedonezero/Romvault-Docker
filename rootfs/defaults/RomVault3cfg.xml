  </DatRules>
  <DirMappings>
    <DirMapping>
      <DirKey>RomVault</DirKey>
      <DirPath>/roms/RomRoot</DirPath>
    </DirMapping>
    <DirMapping>
      <DirKey>ToSort</DirKey>
      <DirPath>/roms/ToSort</DirPath>
    </DirMapping>
  </DirMappings>
  <IgnoreFiles />
  <EInfo />
  <chkBoxShowComplete>true</chkBoxShowComplete>
  <chkBoxShowPartial>true</chkBoxShowPartial>
  <chkBoxShowFixes>true</chkBoxShowFixes>
  <chkBoxShowMIA>true</chkBoxShowMIA>
