#!/bin/bash
# Launched by the KasmVNC desktop session. Working directory must be /config:
# RomVault resolves config/RomVault3cfg.xml, the scan cache, screenpos.xml and
# the default DatRoot relative to the CWD.
#
# Relaunch loop: if the app is closed inside the web desktop, bring it back
# instead of leaving an empty desktop (equivalent of KEEP_APP_RUNNING in the
# jlesage-based images).
cd /config
while true; do
    /app/ROMVault37
    sleep 2
done
