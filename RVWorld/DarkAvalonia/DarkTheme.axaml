<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="RvBg0">#25272C</Color>
    <Color x:Key="RvBg">#2F3136</Color>
    <Color x:Key="RvBg1">#36393F</Color>
    <Color x:Key="RvFg">#D2D2D2</Color>
    <SolidColorBrush x:Key="RvBgBrush0" Color="{DynamicResource RvBg0}" />
    <SolidColorBrush x:Key="RvBgBrush" Color="{DynamicResource RvBg}" />
    <SolidColorBrush x:Key="RvBgBrush1" Color="{DynamicResource RvBg1}" />
    <SolidColorBrush x:Key="RvFgBrush" Color="{DynamicResource RvFg}" />
</ResourceDictionary>
